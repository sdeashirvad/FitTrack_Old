# Supabase Database Configuration
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# Use the direct connection URL for Drizzle schema push/migrations.

DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres?sslmode=require&uselibpqcompat=true"
JWT_SECRET="replace-with-a-secure-random-secret"

# Supabase Auth Configuration
# Supabase Dashboard -> Settings -> API
SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="[YOUR_ANON_KEY]"

# Optional: API server port (default: 5000)
# PORT=5000

# For local development with Supabase emulator, use:
# DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres"
