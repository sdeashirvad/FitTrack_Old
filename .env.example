# Supabase Database Configuration
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# Use the direct connection URL for Drizzle schema push/migrations.

DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres?sslmode=require&uselibpqcompat=true"
JWT_SECRET="replace-with-a-secure-random-secret"

# Supabase Auth Configuration
# Supabase Dashboard -> Settings -> API
SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="[YOUR_ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR_SERVICE_ROLE_KEY]"

# Groq AI API (for InBody analysis)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY="your-groq-api-key-here"

# Groq model to use (default: llama-3.1-8b-instant)
# See available models: https://console.groq.com/docs/models
GROQ_MODEL="llama-3.1-8b-instant"

# Optional: log full raw Groq response for debugging. Do not enable in production.
# LOG_GROQ_RAW_RESPONSE=false

# OCR Services (at least one required for InBody document processing)
# Option 1: Google Cloud Vision API (recommended)
# Get key from: https://console.cloud.google.com/
GOOGLE_VISION_API_KEY="your-google-cloud-vision-key-here"

# Option 2: OCR.space API (fallback)
# Get key from: https://ocr.space/ocrapi
OCR_SPACE_API_KEY="your-ocr-space-key-here"

# Optional: API server port (default: 5000)
# PORT=5000

# For local development with Supabase emulator, use:
# DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres"
